# 이 파일을 `.env`로 복사해서 쓴다. (`.env`는 .gitignore 대상 — 커밋되지 않는다)
# 값을 비워두면 vite.config.ts의 기본값이 쓰인다.

# 배포 도메인 — SEO 전체(canonical / og:url / og:image / sitemap.xml / robots.txt)의 단일 소스.
# ⚠ 기본값 https://snowball-income.example 은 RFC 2606이 예약한 테스트용 TLD라 실제로 해석되지 않는다.
#   실제 도메인으로 바꾸기 전에는 검색엔진 등록과 카카오톡/페이스북 미리보기가 동작하지 않는다.
#   CI/호스팅(Vercel, Netlify, GitHub Actions 등)에서는 이 이름의 환경변수로 주입하면 된다.
VITE_SITE_URL=https://snowball-income.example

# Google Analytics 4 측정 ID (없으면 GA를 아예 로드하지 않는다)
# 이 앱의 측정 ID. 측정 ID는 브라우저에 그대로 노출되는 공개 값이라 커밋해도 안전하다.
VITE_GA_MEASUREMENT_ID=G-VY837P1WK2

# ── 커뮤니티 (Supabase) — 선택 사항 ──────────────────────────────────────────
# 설정 절차: docs/supabase/README.md
#
# ⚠ 아래 두 값이 **둘 다** 있을 때만 커뮤니티(시나리오 갤러리·좋아요·댓글)가 켜진다.
#   비워 두면 커뮤니티만 꺼지고 앱은 지금과 100% 동일하게 동작한다
#   (IndexedDB 저장 + 공유 URL은 백엔드 없이 그대로 작동 — 이게 이 앱의 기본 배포 형태다).
#   하나만 채우면 "반쯤 켜진 상태"를 만들지 않고 꺼진 것으로 취급한다.
#
# anon 키는 **공개값**이다. 브라우저 번들에 그대로 실려 나가도록 설계된 키라 커밋해도 안전하다.
# 이 키로 할 수 있는 일은 전적으로 DB의 RLS 정책이 결정한다 (supabase/migrations/ 참고).
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# 🚫 service_role 키는 절대 여기에 넣지 마라.
#    VITE_ 접두사가 붙은 변수는 전부 번들에 인라인되어 공개된다.
#    service_role은 RLS를 통째로 우회하므로, 노출되는 순간 누구나 모든 사용자의 데이터를
#    읽고 지울 수 있다. 서버(Edge Function) 안에서만 쓰는 키다.
