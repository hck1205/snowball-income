# 이 파일을 `.env`로 복사해서 쓴다. (`.env`는 .gitignore 대상 — 커밋되지 않는다)
# 값을 비워두면 vite.config.ts의 기본값이 쓰인다.

# 배포 도메인 — SEO 전체(canonical / og:url / og:image / sitemap.xml / robots.txt)의 단일 소스.
# ⚠ 기본값 https://snowball-income.example 은 RFC 2606이 예약한 테스트용 TLD라 실제로 해석되지 않는다.
#   실제 도메인으로 바꾸기 전에는 검색엔진 등록과 카카오톡/페이스북 미리보기가 동작하지 않는다.
#   CI/호스팅(Vercel, Netlify, GitHub Actions 등)에서는 이 이름의 환경변수로 주입하면 된다.
VITE_SITE_URL=https://snowball-income.example

# Google Analytics 4 측정 ID (없으면 GA를 아예 로드하지 않는다)
# 이 앱의 측정 ID. 측정 ID는 브라우저에 그대로 노출되는 공개 값이라 커밋해도 안전하다.
VITE_GA_MEASUREMENT_ID=G-VY837P1WK2

# ── 커뮤니티 (Supabase) — 선택 사항 ──────────────────────────────────────────
# 설정 절차: docs/supabase/README.md
#
# ⚠ 아래 두 값이 **둘 다** 있을 때만 커뮤니티(시나리오 갤러리·좋아요·댓글)가 켜진다.
#   비워 두면 커뮤니티만 꺼지고 앱은 지금과 100% 동일하게 동작한다
#   (IndexedDB 저장 + 공유 URL은 백엔드 없이 그대로 작동 — 이게 이 앱의 기본 배포 형태다).
#   하나만 채우면 "반쯤 켜진 상태"를 만들지 않고 꺼진 것으로 취급한다.
#
# anon 키는 **공개값**이다. 브라우저 번들에 그대로 실려 나가도록 설계된 키라 커밋해도 안전하다.
# 이 키로 할 수 있는 일은 전적으로 DB의 RLS 정책이 결정한다 (supabase/migrations/ 참고).
#
# 키 이름은 둘 중 하나를 쓴다 (PUBLISHABLE 이 우선):
#   - 신형 프로젝트: VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
#   - 구형 프로젝트: VITE_SUPABASE_ANON_KEY=eyJ...
#
# ⚠ 이 값들은 커뮤니티 전용이 아니다 — DB key 공유 미리보기(api/og.tsx, api/share-html.ts)도
#   같은 값을 process.env로 서버에서 재사용한다(anon 키만, service_role 불필요). 새 서버 변수 없음.
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=
VITE_SUPABASE_ANON_KEY=

# 🚫 service_role 키에는 절대 VITE_ 접두사를 붙이지 마라.
#    VITE_ 접두사가 붙은 변수는 전부 번들에 인라인되어 공개된다.
#    service_role은 RLS를 통째로 우회하므로, 노출되는 순간 누구나 모든 사용자의 데이터를
#    읽고 지울 수 있다. 아래 SUPABASE_SERVICE_ROLE_KEY처럼 **서버 전용 변수로만** 쓴다
#    (Vercel 서버 함수 — api/account-delete.ts, api/naver-auth.ts).

# ── 네이버 로그인 (선택, 커뮤니티가 켜져 있을 때만 의미있다) ─────────────────────
# 설정 절차: docs/supabase/README.md §7
#
# 네이버는 Supabase 기본 소셜 프로바이더가 아니라서, 이 앱은 Vercel 서버 함수(api/naver-auth.ts)를
# 거쳐 세션을 발급한다. 위 VITE_SUPABASE_URL/키가 없으면(커뮤니티 꺼짐) 네이버도 함께 꺼진다
# (isNaverEnabled = isCommunityEnabled && VITE_NAVER_CLIENT_ID).
#
# 공개값 — 브라우저 번들에 인라인된다. 설정하면 네이버 버튼이 활성화되고, 비워두면 버튼은 사라지지
# 않되 "준비 중"으로 표시되고 클릭이 무시된다.
VITE_NAVER_CLIENT_ID=

# 🚫 서버 전용(Vercel 대시보드에만 등록). 절대 VITE_ 접두사를 붙이지 마라 — 붙는 순간 번들에
#    인라인되어 누구나 브라우저에서 읽을 수 있다. 로컬에서 실제 로그인을 테스트하려면(`npx vercel dev`)
#    이 값을 로컬 .env에 넣어도 되지만, 커밋은 금지.
NAVER_CLIENT_SECRET=

# 🚫 서버 전용. 네이버 로그인(api/naver-auth.ts)과 회원 탈퇴(api/account-delete.ts)가 함께 쓰는
#    Supabase service_role 키 — Project Settings → API에서 복사. RLS를 통째로 우회하므로
#    **VITE_ 접두사 절대 금지, 커밋 금지**.
SUPABASE_SERVICE_ROLE_KEY=

# (선택) 네이버는 이메일을 주지 않아서 서버가 결정론적 "합성 이메일"로 Supabase 계정을 식별한다.
# 비워두면 기본 도메인을 쓴다 — GoTrue 이메일 형식 검증만 통과하면 되므로 실제 소유 도메인일 필요는 없다.
NAVER_SYNTHETIC_EMAIL_DOMAIN=

# ⚠ 로컬 `npm run dev`(순수 Vite)에는 /api 라우트가 없어 위 서버 변수를 채워도 네이버 로그인은
#   항상 실패한다 — 실제 로그인 확인은 `npx vercel dev` 또는 Vercel Preview에서만 가능하다.
