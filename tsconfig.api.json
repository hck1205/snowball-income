{
  /*
    Vercel 서버 코드(`server/handlers/*`, `middleware.ts`) 전용 프로젝트.
    (`api/*.js` 는 이 소스에서 번들된 **생성물**이라 타입체크 대상이 아니다 — tools/apiBundle.)

    앱(tsconfig.app.json)과 분리한 이유:
      - 런타임이 다르다. 브라우저 DOM 이 아니라 Node/Edge 의 Web Fetch API 위에서 돈다.
      - `types: ["node"]` 가 필요하지만, 앱 코드에 node 타입이 새어 들어가면 안 된다.
    `tsc -b tsconfig.build.json` 이 이 프로젝트도 함께 타입체크한다(build.json 의 references).
    (루트 tsconfig.json 은 Vercel 이 읽는 정상 config 로 분리됐다 — 거기 references 는 없다.)
  */
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable", "WebWorker"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "skipLibCheck": true,
    "baseUrl": ".",
    /*
      `vite/client` 가 필요한 이유: `/api/og.tsx` 는 앱 코드(공유 코드 디코더 + 시뮬레이션 엔진)를 그대로
      재사용한다. 그 코드 경로에 `import.meta.env` 를 읽는 파일이 섞여 있어서, node 타입만으로는 타입체크가 깨진다.
      번들러(Vercel=esbuild, Vite)는 둘 다 `import.meta.env` 를 치환해 주므로 런타임에도 문제가 없다.
    */
    "types": ["node", "vite/client"],
    "paths": {
      "@/*": ["./*"]
    }
  },
  "include": ["server", "middleware.ts"]
}
