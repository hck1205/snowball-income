#!/bin/sh
# 커밋 전 인덱스를 항상 신선하게 재생성한다.
# .index/ · .codegraph/ 는 gitignore 대상이므로 스테이징하지 않는다 (각자 로컬에서 생성).
# 활성화(최초 1회): npm run hooks:install   → git config core.hooksPath .githooks

if command -v node >/dev/null 2>&1; then
  node tools/indexer/build-index.mjs || {
    echo "[pre-commit] 인덱싱 실패 — 커밋 중단" >&2
    exit 1
  }
else
  echo "[pre-commit] node를 찾을 수 없어 인덱싱을 건너뜁니다." >&2
fi

# codegraph 지식 그래프 동기화 — 설치돼 있을 때만(선택 도구라 없으면 조용히 건너뛴다).
# codegraph는 평소 파일 와처로 자동 갱신하지만, 와처가 없는 환경(새 clone·CI)에서도
# 커밋 시점에 변경분을 반영하도록 이중 안전망을 둔다. 실패해도 커밋은 막지 않는다(부가 도구).
if command -v codegraph >/dev/null 2>&1; then
  codegraph sync >/dev/null 2>&1 || echo "[pre-commit] codegraph sync 실패(무시) — codegraph status로 확인" >&2
fi

# graphify 지식 그래프 갱신 — 설치돼 있을 때만. AST 재추출만 하므로 LLM/네트워크 비용 0.
# 클러스터링·리포트(GRAPH_REPORT.md)까지 매 커밋 돌리면 느리니 여기선 그래프만 증분 갱신하고,
# 리포트 재생성은 필요할 때 수동으로(`graphify cluster-only . --no-label`). 실패해도 커밋 안 막음.
if command -v graphify >/dev/null 2>&1; then
  graphify update . >/dev/null 2>&1 || echo "[pre-commit] graphify update 실패(무시) — graphify update . 로 확인" >&2
fi

exit 0
