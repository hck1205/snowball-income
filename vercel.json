{
  "$schema": "https://openapi.vercel.sh/vercel.json",

  "rewrites": [
    { "source": "/sitemap-posts.xml", "destination": "/api/sitemap" },
    {
      "source": "/community/portfolio/:id",
      "destination": "/api/post-html?kind=portfolio&id=:id"
    },
    { "source": "/community/board/:id", "destination": "/api/post-html?kind=board&id=:id" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],

  "headers": [
    {
      "source": "/fonts/(.*)",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }]
    }
  ],

  "functions": {
    "api/og.tsx": {
      "maxDuration": 30
    },
    "api/account-delete.ts": {
      "maxDuration": 30
    }
  }
}
